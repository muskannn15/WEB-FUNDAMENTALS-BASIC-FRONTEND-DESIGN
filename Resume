<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Professional Student Profile</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Segoe UI, sans-serif;
}

body{
    background:linear-gradient(135deg,#dbeafe,#bfdbfe,#93c5fd);
    padding:40px;
}

.container{
    max-width:1100px;
    margin:auto;
    background:white;
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 15px 35px rgba(0,0,0,0.2);
}

/* Header */

header{
    background:linear-gradient(to right,#0f172a,#2563eb);
    color:white;
    padding:35px;
}

.profile{
    display:flex;
    align-items:center;
    gap:30px;
}

.profile img{
    width:180px;
    height:180px;
    border-radius:50%;
    border:6px solid white;
    object-fit:cover;
    box-shadow:0 0 20px rgba(255,255,255,.5);
}

.profile-info h1{
    font-size:38px;
}

.profile-info h3{
    margin-top:8px;
    color:#cbd5e1;
}

.profile-info p{
    margin-top:10px;
    font-size:17px;
}

/* Cards */

.card{
    background:#ffffff;
    margin:25px;
    padding:25px;
    border-radius:15px;
    box-shadow:0 8px 20px rgba(0,0,0,.12);
    transition:.3s;
}

.card:hover{
    transform:translateY(-8px);
}

.card h2{
    color:#2563eb;
    margin-bottom:18px;
    border-left:6px solid #2563eb;
    padding-left:12px;
}

/* Personal Details */

.details{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:15px;
}

.details div{
    background:#eff6ff;
    padding:15px;
    border-radius:10px;
    font-size:17px;
}

/* Table */

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background:#2563eb;
    color:white;
    padding:15px;
}

td{
    text-align:center;
    padding:12px;
    border-bottom:1px solid #ddd;
}

tr:nth-child(even){
    background:#f8fafc;
}

tr:hover{
    background:#dbeafe;
}

/* Hobbies */

.hobby-list{
    display:flex;
    flex-wrap:wrap;
    gap:15px;
}

.hobby{
    background:#2563eb;
    color:white;
    padding:12px 22px;
    border-radius:25px;
    font-weight:bold;
    transition:.3s;
}

.hobby:hover{
    background:#1e40af;
    transform:scale(1.05);
}

/* Contact */

.contact p{
    margin:12px 0;
    font-size:18px;
}

/* Footer */

footer{
    background:#0f172a;
    color:white;
    text-align:center;
    padding:18px;
    margin-top:20px;
}

@media(max-width:768px){

.profile{
    flex-direction:column;
    text-align:center;
}

.details{
    grid-template-columns:1fr;
}

}

</style>

</head>
